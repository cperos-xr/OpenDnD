  "gateway": {
    "port": 18785,
    "mode": "local",
    "bind": "lan",
    "controlUi": {
      "allowedOrigins": [
        "http://127.0.0.1:18786",
        "http://localhost:18786"
      ],
      "allowInsecureAuth": true,
      "dangerouslyDisableDeviceAuth": true
