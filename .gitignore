# =========================================
# SECRETS & CREDENTIALS  — never commit these
# =========================================
credentials/
devices/
identity/

# openclaw.json has gateway tokens + API keys — use openclaw.json.template instead
openclaw.json
openclaw.json.bak
openclaw.json.bak.*

# .env files have all API keys — use .env.instance3.template instead
*.env
.env*

# =========================================
# PRIVATE CONVERSATION HISTORY
# =========================================
agents/*/sessions/
**/sessions/*.jsonl

# =========================================
# RUNTIME / GENERATED / CACHE
# =========================================
logs/
completions/
canvas/
update-check.json
restart-sentinel.json

# Workspace runtime state (not human-edited)
workspace/.openclaw/
workspace-*/.openclaw/

# =========================================
# OS NOISE
# =========================================
.DS_Store
.DS_Store?
._*
Thumbs.db
